Quick search:

# Every file that could contain a secret
Get-ChildItem -Recurse -Include *.cmd,*.bat,*.xml,*.ini,*.properties,*.conf,*.txt,*.cnf -Exclude logfile.txt | Select-Object FullName, Length, LastWriteTime | Sort-Object FullName

$patterns = "password|pwd|passwd|secret|key|credential|auth|token|jdbc|connectionstring|truststorepassword|keystorepassword|storepass|user=|pass=|username"
Get-ChildItem -Recurse -Include *.cmd,*.bat,*.xml,*.ini,*.properties,*.conf,*.txt -Exclude logfile.txt | Select-String -Pattern $patterns -CaseSensitive:$false -SimpleMatch

searching secrets:
# Quick string grep for high-value keywords
strings64.exe .\mxboot.jar | findstr /i "password secret key jdbc oracle truststore keystore murex westpac obm nix srv 9100 https http user pass auth token credential"

# Also grep for Java property patterns (common in bootstraps)
strings64.exe .\mxboot.jar | findstr /i "javax.net.ssl trustStorePassword keyStorePassword java.rmi.server.codebase sun.net"

# Look for potential Base64 blobs (length >20, alphanumeric + / + =)
strings64.exe .\mxboot.jar | findstr /r "^[A-Za-z0-9+/]\{20,\}==\{0,2\}$"




